# PostgreSQL
POSTGRES_USER=linerelay
POSTGRES_PASSWORD=linerelay_dev_2026
POSTGRES_DB=linerelay
DATABASE_URL=postgresql://linerelay:linerelay_dev_2026@postgres:5432/linerelay

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (开发阶段) / AWS S3 (生产阶段)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=linerelay-videos
# 生产阶段切换为:
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=你的AWS_ACCESS_KEY
# S3_SECRET_KEY=你的AWS_SECRET_KEY

# LLM
DEEPSEEK_API_KEY=你的key
LLM_PROVIDER=deepseek-flash
ANTHROPIC_API_KEY=你的key
OPENAI_API_KEY=你的key

# Gemini Embedding
GEMINI_API_KEY=你的key

# clip.cafe
CLIPCAFE_API_URL=https://api.clip.cafe

# OpenSubtitles
OPENSUBTITLES_API_KEY=你的key（去 https://www.opensubtitles.com/consumers 免费注册）

# 限流
GLOBAL_DAILY_LIMIT=100
IP_DAILY_LIMIT=3
FREQ_LIMIT_SECONDS=30

# Admin
ADMIN_TOKEN=你的secret token
